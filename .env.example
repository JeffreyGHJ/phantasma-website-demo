# Copy this file to .env and fill in the values.
# .env is gitignored and should never be committed.

# BSC RPC endpoint (public nodes work fine for read-only demo)
REACT_APP_NETWORK_URL="https://bsc-dataseed1.binance.org/"

# Chain ID: 56 = BSC Mainnet, 97 = BSC Testnet
REACT_APP_CHAIN_ID="56"

# Google Tag Manager container ID (optional)
REACT_APP_GTAG=""

# Backend API base URL
REACT_APP_API=""

# Secondary/local API URL
REACT_APP_API2="http://localhost:8080"

# Build flag
GENERATE_SOURCEMAP=false

# Client-side JWT signing secret (used only for local mock auth)
REACT_APP_JWT_SECRET=""

# Google reCAPTCHA site keys (v2 checkbox, invisible, and alternate)
REACT_APP_RECAPTCHA_SITE_KEY=""
REACT_APP_RECAPTCHA_INVISIBLE_SITE_KEY=""
REACT_APP_RECAPTCHA_SITE_KEY_ALT=""

# Infura project ID for Ethereum RPC
REACT_APP_INFURA_KEY=""

# Ethereum RPC URL (falls back to https://eth.llamarpc.com if unset)
REACT_APP_ETH_NETWORK_URL=""
